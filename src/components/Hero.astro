---
// src/components/Hero.astro
---

<section class="relative h-screen min-h-[800px] w-full bg-deep-burgundy overflow-hidden flex flex-col items-center justify-center pt-20">
  
  <div class="absolute inset-0 z-0 bg-noise opacity-40 mix-blend-overlay"></div>
  <div class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,rgba(217,4,41,0.15)_0%,transparent_100%)]"></div>
  <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-deep-raisin to-transparent z-10"></div>

  <div class="relative z-20 mx-auto max-w-5xl px-6 text-center">
    
    <h1 class="font-display text-[clamp(2.5rem,6vw,5.5rem)] font-bold tracking-tight text-pure-white leading-[1.1] animate-fade-up" style="animation-delay: 100ms;">
      We build zero-touch infrastructure <br />
      <span class="text-pure-white/50 block mt-2 font-medium text-[clamp(2rem,5vw,4.5rem)]">
        for ambitious <br class="sm:hidden" />
        <span class="inline-grid h-[1.2em] overflow-hidden text-pure-white align-bottom">
          <span class="animate-rotate-text text-left">
            <span>brands.</span>
            <span>enterprises.</span>
            <span>operations.</span>
            <span>scaling.</span>
            <span>brands.</span> </span>
        </span>
      </span>
    </h1>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5 animate-fade-up" style="animation-delay: 300ms;">
      <a href="#portfolio" class="group flex h-14 items-center justify-center gap-2 rounded-full bg-pure-white px-8 text-sm font-bold text-deep-black transition-transform hover:scale-105">
        View Work 
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      
      <a href="#process" class="flex h-14 items-center justify-center rounded-full border border-pure-white/20 px-8 text-sm font-semibold text-pure-white hover:bg-pure-white/10 transition-colors">
        Our Process
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 z-20 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade-up" style="animation-delay: 600ms;">
    <span class="text-xs font-semibold uppercase tracking-widest text-pure-white/40">Scroll to explore</span>
    <div class="h-10 w-[1px] bg-gradient-to-b from-pure-white/40 to-transparent"></div>
  </div>
</section>