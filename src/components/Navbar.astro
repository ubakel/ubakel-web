---
// src/components/Navbar.astro
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-pure-white/10 bg-deep-raisin/80 backdrop-blur-md transition-all">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-4 lg:px-8" aria-label="Global">
    
    <div class="flex lg:flex-1">
  <a href="/" class="-m-1.5 p-1.5 flex items-center gap-2">
    <span class="sr-only">Ubakel</span>
    <img class="h-8 w-auto" src="/logo.svg" alt="Ubakel Logo" />
  </a>
</div>

    <div class="hidden lg:flex lg:gap-x-12">
      <a href="#services" class="text-sm font-semibold leading-6 text-pure-white/80 hover:text-pure-white transition">Services</a>
      <a href="#portfolio" class="text-sm font-semibold leading-6 text-pure-white/80 hover:text-pure-white transition">Work</a>
      <a href="#process" class="text-sm font-semibold leading-6 text-pure-white/80 hover:text-pure-white transition">Process</a>
    </div>

    <div class="flex flex-1 justify-end">
      <a href="#contact" class="rounded-full border border-pure-white/20 bg-pure-white/5 px-6 py-2.5 text-sm font-semibold text-pure-white hover:bg-pure-white hover:text-deep-black transition-all">
        Get in touch
      </a>
    </div>
  </nav>
</header>