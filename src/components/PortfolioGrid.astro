---
// Services.astro — UBAKEL Services Section
const services = [
  {
    number: '01',
    title: 'Workflow Automation',
    description: 'We map, design, and deploy end-to-end automated workflows that eliminate manual bottlenecks and scale with your business.',
    tags: ['Make.com', 'Zapier', 'n8n', 'APIs'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 16h8v16H8zM20 8h8v32h-8zM32 20h8v12h-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
  {
    number: '02',
    title: 'AI Integration',
    description: 'Embed large language models, computer vision, and predictive analytics directly into your existing tools and processes.',
    tags: ['OpenAI', 'Claude', 'LangChain', 'Custom LLMs'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M24 4v6M24 38v6M4 24h6M38 24h6M9.4 9.4l4.2 4.2M34.4 34.4l4.2 4.2M9.4 38.6l4.2-4.2M34.4 13.6l4.2-4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    number: '03',
    title: 'CRM Automation',
    description: 'From lead capture to client onboarding — we engineer CRM flows that nurture relationships without human intervention.',
    tags: ['HubSpot', 'Salesforce', 'Airtable', 'GoHighLevel'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="16" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 40c0-8.837 7.163-12 16-12s16 3.163 16 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    number: '04',
    title: 'Data Pipelines',
    description: 'Real-time data collection, transformation, and routing — so decision-makers always have accurate, up-to-date intelligence.',
    tags: ['Webhooks', 'SQL', 'BigQuery', 'Sheets API'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 12l10 10L8 32M22 32h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="38" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    number: '05',
    title: 'E-commerce Automation',
    description: 'Inventory sync, order fulfillment, abandoned cart recovery, and post-purchase flows — built to convert and retain at scale.',
    tags: ['Shopify', 'WooCommerce', 'Klaviyo', 'Stripe'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 10h4l5 22h18l5-16H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="20" cy="38" r="2.5" stroke="currentColor" stroke-width="1.5"/><circle cx="32" cy="38" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    number: '06',
    title: 'Custom Dashboards',
    description: 'Unified reporting views that aggregate data from every tool you use — giving leadership a single source of operational truth.',
    tags: ['Retool', 'Looker', 'Notion', 'Custom'],
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="6" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="26" y="6" width="16" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="26" y="19" width="16" height="23" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="6" y="26" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
];
---

<section class="services" id="services" aria-labelledby="services-title">
  <div class="container">

    <header class="services__header">
      <div class="section-label reveal">Our Capabilities</div>
      <h2 class="display-lg services__title reveal" data-delay="100" id="services-title">
        What we build<br /><em>for you</em>
      </h2>
      <p class="body-lg services__intro reveal" data-delay="200">
        Every service is delivered as a complete, production-ready system —<br class="br-desk" />
        not a half-finished prototype.
      </p>
    </header>

    <div class="services__grid">
      {services.map((s, i) => (
        <article class="service-card reveal" data-delay={String(i * 80)} aria-label={s.title}>
          <div class="service-card__top">
            <span class="service-card__number">{s.number}</span>
            <div class="service-card__icon" aria-hidden="true" set:html={s.icon} />
          </div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.description}</p>
          <div class="service-card__tags">
            {s.tags.map(tag => (
              <span class="service-card__tag">{tag}</span>
            ))}
          </div>
          <div class="service-card__hover-line" aria-hidden="true"></div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
/* ══ Services ══════════════════════════════════════════════ */
.services {
  padding: var(--space-xl) 0;
  background: var(--crisp-grey);
}

.services__header {
  max-width: 640px;
  margin-bottom: 5rem;
}

.services__title {
  margin-bottom: 1.5rem;
  color: var(--deep-black);
}

.services__title em {
  font-style: italic;
  color: var(--cool-slate);
}

.services__intro {
  color: var(--cool-slate);
}

/* ── Service grid ──────────────────────────────────────── */
.services__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5px;
  background: rgba(0,0,0,0.08);
  border: 1.5px solid rgba(0,0,0,0.08);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

/* ── Service card ──────────────────────────────────────── */
.service-card {
  position: relative;
  background: var(--crisp-grey);
  padding: 2.5rem;
  transition: background 0.4s var(--ease-out-expo);
  cursor: default;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(107, 26, 42, 0.04) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s;
}

.service-card:hover { background: var(--white); }
.service-card:hover::before { opacity: 1; }

.service-card__hover-line {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--deep-burgundy);
  transition: width 0.5s var(--ease-out-expo);
}

.service-card:hover .service-card__hover-line { width: 100%; }

.service-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 1.75rem;
}

.service-card__number {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--deep-burgundy);
  letter-spacing: 0.12em;
  opacity: 0.6;
  padding-top: 0.15rem;
}

.service-card__icon {
  width: 40px;
  height: 40px;
  color: var(--deep-burgundy);
  opacity: 0.7;
  transition: opacity 0.3s, transform 0.3s var(--ease-out-expo);
}

.service-card:hover .service-card__icon {
  opacity: 1;
  transform: scale(1.08);
}

.service-card__title {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--deep-black);
  margin-bottom: 0.75rem;
  transition: color 0.3s;
}

.service-card:hover .service-card__title { color: var(--deep-burgundy); }

.service-card__desc {
  font-size: 0.9rem;
  line-height: 1.7;
  color: var(--cool-slate);
  margin-bottom: 1.75rem;
}

.service-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.service-card__tag {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  padding: 0.3rem 0.8rem;
  background: rgba(107, 26, 42, 0.07);
  color: var(--deep-burgundy);
  border-radius: var(--radius-pill);
  border: 1px solid rgba(107, 26, 42, 0.12);
}

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 1024px) {
  .services__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
  .services__grid { grid-template-columns: 1fr; background: transparent; border: none; gap: 1rem; }
  .service-card { border-radius: var(--radius-md); border: 1.5px solid rgba(0,0,0,0.08); }
  .services { padding: var(--space-lg) 0; }
}
</style>