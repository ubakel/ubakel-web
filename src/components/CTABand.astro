---
// src/components/CTABand.astro
---
<section class="bg-deep-black py-32 text-center px-6 relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-sharp-crimson/10 blur-[120px] rounded-full pointer-events-none z-0"></div>
  
  <div class="relative z-10 max-w-3xl mx-auto flex flex-col items-center">
    <h2 class="text-[clamp(2.5rem,5vw,4rem)] font-display font-bold text-pure-white leading-tight mb-6">
      Ready to automate your enterprise?
    </h2>
    <p class="text-pure-white/60 text-lg mb-10 max-w-xl">
      Stop wasting hours on manual data entry. Deploy zero-touch infrastructure today.
    </p>
    
    <a href="#contact" class="group flex items-center justify-center gap-2 rounded-full bg-sharp-crimson px-10 py-4 text-base font-bold text-pure-white transition-all hover:scale-105 hover:shadow-[0_0_30px_rgba(217,4,41,0.4)]">
      Start a Project 
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
    </a>
  </div>
</section>