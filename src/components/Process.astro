---
// src/components/Process.astro
const steps = [
  { num: "01", title: "Discovery", desc: "Mapping your manual bottlenecks." },
  { num: "02", title: "Architecture", desc: "Designing the event-driven pipelines." },
  { num: "03", title: "Build", desc: "Developing the secure automation engines." },
  { num: "04", title: "Launch", desc: "Deploying the zero-touch infrastructure." }
];
---
<section id="process" class="bg-crisp-grey py-24 sm:py-32 relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-16">
      <h2 class="text-3xl font-display font-bold text-deep-black animate-fade-up">Deployment Protocol</h2>
    </div>

    <div class="relative">
      <div class="hidden lg:block absolute top-12 left-0 w-full h-[2px] bg-cool-slate/20 z-0"></div>
      
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-10 lg:gap-8 relative z-10">
        {steps.map((step, index) => (
          <div class="relative group animate-fade-up" style={`animation-delay: ${index * 150}ms;`}>
            <div class="w-24 h-24 rounded-full bg-pure-white border-4 border-crisp-grey shadow-sm flex items-center justify-center mb-6 transition-transform duration-500 group-hover:scale-110">
              <span class="text-2xl font-display font-bold text-sharp-crimson">{step.num}</span>
            </div>
            <h3 class="text-xl font-bold text-deep-black mb-2">{step.title}</h3>
            <p class="text-sm text-cool-slate pr-4">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>